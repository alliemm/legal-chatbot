{
  "manifest_version": 3,
  "name": "Legaleye",
  "version": "1.0.0",
  "description": "AI-driven contract intelligence and legal summaries in your browser.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png",
    "default_title": "Legaleye"
  },
  "icons": { "48": "icon.png", "128": "icon.png" }
}
