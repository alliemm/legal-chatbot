{
  "manifest_version": 3,
  "name": "LexAssist AI",
  "version": "1.0",
  "permissions": ["sidePanel", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "index.html"
  }
}